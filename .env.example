# ─── E-Commerce Order Tracker — Environment Variables ────────────────────────
# Copy this file to .env and fill in production values

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=orderdb
DB_USER=postgres
DB_PASS=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_SERVERS=kafka:29092

# JWT — IMPORTANT: Replace with a strong random secret in production
# Generate with: openssl rand -hex 64
JWT_SECRET=7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b

# Service hosts (for api-gateway routing)
ORDER_SERVICE_HOST=order-service
NOTIFICATION_SERVICE_HOST=notification-service
